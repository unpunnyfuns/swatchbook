{
  "$schema": "https://design-tokens.org/tr/2025/drafts/resolver/",
  "version": "2025.10",
  "name": "swatchbook-docs",
  "description": "Docusaurus-site tokens. A brand ramp + per-mode surface/text/primary/code roles that the Infima layer in src/css/custom.css reads through `var(--sb-color-*)`. Second axis (`a11y`) layers a high-contrast overlay on top of the mode tokens.",
  "sets": {
    "tokens": {
      "description": "Palette primitives.",
      "sources": [{ "$ref": "./color.json" }]
    }
  },
  "modifiers": {
    "mode": {
      "contexts": {
        "Light": [{ "$ref": "./themes/light.json" }],
        "Dark": [{ "$ref": "./themes/dark.json" }]
      },
      "default": "Light"
    },
    "a11y": {
      "contexts": {
        "Normal": [],
        "High-contrast": [{ "$ref": "./themes/high-contrast.json" }]
      },
      "default": "Normal"
    }
  },
  "resolutionOrder": [
    { "$ref": "#/sets/tokens" },
    { "$ref": "#/modifiers/mode" },
    { "$ref": "#/modifiers/a11y" }
  ]
}
