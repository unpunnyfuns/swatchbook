{
  "$description": "Dark theme role tokens the Docusaurus Infima layer maps onto.",
  "color": {
    "$type": "color",
    "surface": {
      "default": { "$value": "{color.palette.neutral.900}" },
      "raised":  { "$value": "{color.palette.neutral.800}" },
      "muted":   { "$value": "{color.palette.neutral.950}" }
    },
    "text": {
      "default": { "$value": "{color.palette.neutral.100}" },
      "muted":   { "$value": "{color.palette.neutral.300}" },
      "heading": { "$value": "{color.palette.neutral.0}" }
    },
    "primary": {
      "lightest": { "$value": "{color.palette.brand.200}" },
      "lighter":  { "$value": "{color.palette.brand.300}" },
      "light":    { "$value": "{color.palette.brand.400}" },
      "default":  { "$value": "{color.palette.brand.500}" },
      "dark":     { "$value": "{color.palette.brand.600}" },
      "darker":   { "$value": "{color.palette.brand.700}" },
      "darkest":  { "$value": "{color.palette.brand.800}" }
    },
    "code": {
      "bg":     { "$value": "{color.palette.neutral.800}" },
      "border": { "$value": "{color.palette.neutral.700}" }
    },
    "accessible": {
      "$description": "High-contrast alternates for Dark. Lighter neutrals for muted text; amber ramp for primary — bright yellow sits high above the dark surface ramp for unmistakable link contrast. Parallel shape to light's `color.accessible`; the a11y overlay aliases role tokens to this namespace and the active mode's definitions decide the resolved value.",
      "text": {
        "muted": { "$value": "{color.palette.neutral.100}" }
      },
      "primary": {
        "lightest": { "$value": "{color.palette.amber.100}" },
        "lighter":  { "$value": "{color.palette.amber.200}" },
        "light":    { "$value": "{color.palette.amber.300}" },
        "default":  { "$value": "{color.palette.amber.300}" },
        "dark":     { "$value": "{color.palette.amber.400}" },
        "darker":   { "$value": "{color.palette.amber.500}" },
        "darkest":  { "$value": "{color.palette.amber.600}" }
      }
    }
  },
  "font": {
    "family": {
      "$type": "fontFamily",
      "base": { "$value": "{font.family.system}" }
    },
    "size": {
      "$type": "dimension",
      "base": { "$value": { "value": 100, "unit": "%" } }
    }
  }
}
