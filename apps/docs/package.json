  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@types/react": "^19.2.17",
    "@types/react-dom": "19.2.3",
    "@unpunnyfuns/swatchbook-core": "workspace:*",
    "playwright": "^1.59.1",
