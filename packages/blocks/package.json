{
  "name": "@unpunnyfuns/swatchbook-blocks",
  "version": "2.0.0",
  "description": "Storybook MDX doc blocks for DTCG design tokens — TokenTable, ColorPalette, TypographyScale, TokenDetail.",
  "keywords": [
    "design-system",
    "design-tokens",
    "dtcg",
    "mdx",
    "organize",
    "storybook",
    "storybook-blocks",
    "tokens"
  ],
  "homepage": "https://unpunnyfuns.github.io/swatchbook/",
  "bugs": "https://github.com/unpunnyfuns/swatchbook/issues",
  "license": "MIT",
  "author": "unpunnyfuns <unpunnyfuns@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unpunnyfuns/swatchbook.git",
    "directory": "packages/blocks"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "imports": {
    "#/*": "./src/*"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./host": {
      "types": "./dist/host.d.mts",
      "import": "./dist/host.mjs"
    },
    "./style.css": "./dist/style.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "generate:scales": "node scripts/generate-internal-scales.mts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "coverage": "vitest run --coverage --coverage.provider=v8 --coverage.reporter=text --coverage.include='src/**' --coverage.all",
    "test:watch": "vitest",
    "lint": "oxlint --deny-warnings -c ../../.oxlintrc.json src test",
    "format": "oxfmt -c ../../.oxfmtrc.json src test",
    "format:check": "oxfmt --check -c ../../.oxfmtrc.json src test"
  },
  "dependencies": {
    "@tanstack/react-virtual": "3.14.5",
    "@unpunnyfuns/swatchbook-core": "workspace:*",
    "clsx": "^2.1.1",
    "colorjs.io": "^0.6.1"
  },
  "devDependencies": {
    "@terrazzo/token-tools": "^2.3.0",
    "@testing-library/react": "^16.3.2",
    "@tsdown/css": "^0.21.9",
    "@types/react": "^19.2.14",
    "@unpunnyfuns/swatchbook-tokens": "workspace:*",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.1.8",
    "@vitest/browser-playwright": "^4.1.8",
    "playwright": "^1.59.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsdown": "^0.21.9",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "engines": {
    "node": ">=24.14.0"
  }
}
