{
  "name": "@unpunnyfuns/swatchbook-core",
  "version": "0.0.0",
  "description": "Framework-free core for loading and emitting DTCG design tokens.",
  "type": "module",
  "engines": {
    "node": ">=24.14.0"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "imports": {
    "#/*": "./src/*.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --format esm --dts --clean --sourcemap",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint -c ../../.oxlintrc.json src",
    "format": "oxfmt -c ../../.oxfmtrc.json src",
    "format:check": "oxfmt --check -c ../../.oxfmtrc.json src"
  },
  "dependencies": {
    "@terrazzo/parser": "^2.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsdown": "^0.21.9",
    "typescript": "^6.0.0"
  }
}
