{
  "color": {
    "$type": "color",
    "text": { "$value": "#ffffff" },
    "border": {
      "focus": { "$value": "{color.text}" }
    }
  },
  "border": {
    "$type": "border",
    "input": {
      "$value": {
        "color": "#ffffff",
        "width": { "value": 2, "unit": "px" },
        "style": "solid"
      }
    }
  }
}
