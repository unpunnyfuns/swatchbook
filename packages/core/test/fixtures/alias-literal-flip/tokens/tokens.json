{
  "color": {
    "$type": "color",
    "a": { "$value": "#000000" },
    "text": { "$value": "{color.a}" },
    "border": {
      "focus": { "$value": "{color.a}" }
    }
  },
  "border": {
    "$type": "border",
    "input": {
      "$value": {
        "color": "{color.a}",
        "width": "1px",
        "style": "solid"
      }
    }
  }
}
