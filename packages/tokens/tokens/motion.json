{
  "duration": {
    "$type": "duration",
    "instant": { "$value": { "value": 0,   "unit": "ms" } },
    "fast":    { "$value": { "value": 120, "unit": "ms" } },
    "normal":  { "$value": { "value": 240, "unit": "ms" } },
    "slow":    { "$value": { "value": 400, "unit": "ms" } }
  },
  "cubicBezier": {
    "$type": "cubicBezier",
    "$description": "Google Material 3 easing curves.",
    "standard":    { "$value": [0.2, 0.0, 0.0, 1.0] },
    "emphasized":  { "$value": [0.3, 0.0, 0.0, 1.0] },
    "decelerated":{ "$value": [0.0, 0.0, 0.0, 1.0] },
    "accelerated":{ "$value": [0.3, 0.0, 1.0, 1.0] }
  },
  "transition": {
    "$type": "transition",
    "$description": "Composite transitions combining duration and easing.",
    "enter": {
      "$value": {
        "duration":       "{duration.normal}",
        "delay":          "{duration.instant}",
        "timingFunction": "{cubicBezier.decelerated}"
      }
    },
    "exit": {
      "$value": {
        "duration":       "{duration.fast}",
        "delay":          "{duration.instant}",
        "timingFunction": "{cubicBezier.accelerated}"
      }
    },
    "emphasized": {
      "$value": {
        "duration":       "{duration.slow}",
        "delay":          "{duration.instant}",
        "timingFunction": "{cubicBezier.emphasized}"
      }
    }
  }
}
