{
  "font": {
    "family": {
      "$type": "fontFamily",
      "sans": { "$value": ["Geist", "Inter", "system-ui", "-apple-system", "sans-serif"] },
      "serif":{ "$value": ["Source Serif 4", "Georgia", "serif"] },
      "mono": { "$value": ["Geist Mono", "JetBrains Mono", "Menlo", "monospace"] },
      "comic":{ "$value": ["Comic Sans MS", "Comic Neue", "Chalkboard SE", "Marker Felt", "cursive"] }
    },
    "weight": {
      "$type": "fontWeight",
      "regular":  { "$value": 400 },
      "medium":   { "$value": 500 },
      "semibold": { "$value": 600 },
      "bold":     { "$value": 700 }
    },
    "size": {
      "$type": "dimension",
      "$description": "rem font-size primitives for the block-UI type scale.",
      "100": { "$value": { "value": 0.6875, "unit": "rem" } },
      "200": { "$value": { "value": 0.75,   "unit": "rem" } },
      "300": { "$value": { "value": 0.875,  "unit": "rem" } },
      "400": { "$value": { "value": 1,      "unit": "rem" } },
      "500": { "$value": { "value": 1.25,   "unit": "rem" } },
      "600": { "$value": { "value": 1.5,    "unit": "rem" } },
      "700": { "$value": { "value": 1.75,   "unit": "rem" } },
      "800": { "$value": { "value": 2,      "unit": "rem" } }
    },
    "scale": {
      "$type": "dimension",
      "$description": "T-shirt aliases over the rem font-size primitives.",
      "2xs": { "$value": "{font.size.100}" },
      "xs":  { "$value": "{font.size.200}" },
      "sm":  { "$value": "{font.size.300}" },
      "md":  { "$value": "{font.size.400}" },
      "lg":  { "$value": "{font.size.500}" },
      "xl":  { "$value": "{font.size.600}" },
      "2xl": { "$value": "{font.size.700}" },
      "3xl": { "$value": "{font.size.800}" }
    }
  }
}
