{
  "name": "@unpunnyfuns/swatchbook-tokens",
  "version": "0.0.0",
  "description": "Exhaustive DTCG token set — the dogfood fixture the reference Storybook renders against, and a reference for consumers structuring their own token projects.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.14.0"
  },
  "exports": {
    ".": "./src/index.ts",
    "./tokens/*": "./tokens/*"
  },
  "files": [
    "src",
    "tokens"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --deny-warnings -c ../../.oxlintrc.json src",
    "format": "oxfmt -c ../../.oxfmtrc.json src",
    "format:check": "oxfmt --check -c ../../.oxfmtrc.json src"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.0"
  }
}
