{
  "font": {
    "family": {
      "$type": "fontFamily",
      "sans": { "$value": ["Inter", "system-ui", "-apple-system", "sans-serif"] },
      "serif":{ "$value": ["Source Serif 4", "Georgia", "serif"] },
      "mono": { "$value": ["JetBrains Mono", "Menlo", "monospace"] }
    },
    "weight": {
      "$type": "fontWeight",
      "regular":  { "$value": 400 },
      "medium":   { "$value": 500 },
      "semibold": { "$value": 600 },
      "bold":     { "$value": 700 }
    }
  }
}
