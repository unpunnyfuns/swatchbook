{
  "size": {
    "ref": {
      "$type": "dimension",
      "$description": "4px-based linear scale. Every dimension token in sys aliases into here.",
      "000": { "$value": { "value": 0,   "unit": "px" } },
      "050": { "$value": { "value": 2,   "unit": "px" } },
      "100": { "$value": { "value": 4,   "unit": "px" } },
      "200": { "$value": { "value": 8,   "unit": "px" } },
      "300": { "$value": { "value": 12,  "unit": "px" } },
      "400": { "$value": { "value": 16,  "unit": "px" } },
      "500": { "$value": { "value": 20,  "unit": "px" } },
      "600": { "$value": { "value": 24,  "unit": "px" } },
      "700": { "$value": { "value": 32,  "unit": "px" } },
      "800": { "$value": { "value": 40,  "unit": "px" } },
      "900": { "$value": { "value": 48,  "unit": "px" } },
      "1000":{ "$value": { "value": 64,  "unit": "px" } },
      "2000":{ "$value": { "value": 96,  "unit": "px" } },

      "rem-100": { "$value": { "value": 0.25, "unit": "rem" } },
      "rem-400": { "$value": { "value": 1,    "unit": "rem" } },
      "rem-500": { "$value": { "value": 1.25, "unit": "rem" } },
      "rem-700": { "$value": { "value": 2,    "unit": "rem" } }
    }
  }
}
