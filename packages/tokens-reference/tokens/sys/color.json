{
  "color": {
    "sys": {
      "$type": "color",
      "$description": "Semantic color slots. Theme files override these.",
      "surface": {
        "default":   { "$value": "{color.ref.neutral.0}" },
        "muted":     { "$value": "{color.ref.neutral.50}" },
        "subtle":    { "$value": "{color.ref.neutral.100}" },
        "inverse":   { "$value": "{color.ref.neutral.900}" },
        "raised":    { "$value": "{color.ref.neutral.0}" }
      },
      "text": {
        "default":   { "$value": "{color.ref.neutral.900}" },
        "muted":     { "$value": "{color.ref.neutral.600}" },
        "subtle":    { "$value": "{color.ref.neutral.500}" },
        "inverse":   { "$value": "{color.ref.neutral.0}" },
        "accent":    { "$value": "{color.ref.blue.700}" },
        "danger":    { "$value": "{color.ref.red.700}" },
        "success":   { "$value": "{color.ref.green.700}" }
      },
      "border": {
        "default":   { "$value": "{color.ref.neutral.200}" },
        "strong":    { "$value": "{color.ref.neutral.400}" },
        "focus":     { "$value": "{color.ref.blue.500}" }
      },
      "accent": {
        "bg":        { "$value": "{color.ref.blue.500}" },
        "bg-hover":  { "$value": "{color.ref.blue.700}" },
        "fg":        { "$value": "{color.ref.neutral.0}" }
      },
      "status": {
        "success-bg": { "$value": "{color.ref.green.100}" },
        "success-fg": { "$value": "{color.ref.green.700}" },
        "danger-bg":  { "$value": "{color.ref.red.100}" },
        "danger-fg":  { "$value": "{color.ref.red.700}" },
        "warning-bg": { "$value": "{color.ref.yellow.100}" },
        "warning-fg": { "$value": "{color.ref.yellow.700}" }
      }
    }
  }
}
