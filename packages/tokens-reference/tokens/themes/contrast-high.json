{
  "color": {
    "$type": "color",
    "$description": "High-contrast overlay — strengthens borders and focus rings. Surfaces and accents stay in mode/brand's lane.",
    "border": {
      "default": { "$value": "{color.palette.neutral.700}" },
      "strong":  { "$value": "{color.palette.neutral.900}" },
      "focus":   { "$value": "{color.palette.yellow.500}" }
    },
    "text": {
      "muted":  { "$value": "{color.palette.neutral.700}" },
      "subtle": { "$value": "{color.palette.neutral.600}" }
    }
  },
  "border": {
    "$type": "border",
    "$description": "High-contrast border widths — composite bumps to 2px default, 3px focus.",
    "default": {
      "$value": {
        "color": "{color.border.default}",
        "width": { "value": 2, "unit": "px" },
        "style": "solid"
      }
    },
    "strong": {
      "$value": {
        "color": "{color.border.strong}",
        "width": { "value": 2, "unit": "px" },
        "style": "solid"
      }
    },
    "focus": {
      "$value": {
        "color": "{color.border.focus}",
        "width": { "value": 3, "unit": "px" },
        "style": "solid"
      }
    }
  }
}
