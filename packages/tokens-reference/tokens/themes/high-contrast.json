{
  "color": {
    "sys": {
      "$type": "color",
      "$description": "High-contrast theme — stronger borders, pure black/white text.",
      "surface": {
        "default": { "$value": "{color.ref.neutral.0}" },
        "inverse": { "$value": "{color.ref.neutral.1000}" }
      },
      "text": {
        "default": { "$value": "{color.ref.neutral.1000}" },
        "muted":   { "$value": "{color.ref.neutral.900}" },
        "subtle":  { "$value": "{color.ref.neutral.800}" },
        "inverse": { "$value": "{color.ref.neutral.0}" }
      },
      "border": {
        "default": { "$value": "{color.ref.neutral.1000}" },
        "strong":  { "$value": "{color.ref.neutral.1000}" },
        "focus":   { "$value": "{color.ref.yellow.500}" }
      }
    }
  }
}
