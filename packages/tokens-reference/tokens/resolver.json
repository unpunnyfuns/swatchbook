{
  "$schema": "https://design-tokens.org/tr/2025/drafts/resolver/",
  "version": "2025.10",
  "name": "swatchbook-reference",
  "description": "DTCG 2025.10 native resolver. Two independent modifiers — `mode` (light/dark base) and `brand` (default/Brand A accent) — compose into a 4-permutation cartesian product. High-contrast is deferred pending a proper contrast-orthogonal design; see issue #132.",
  "sets": {
    "ref": {
      "description": "Raw primitives (loaded but not emitted).",
      "sources": [
        { "$ref": "./ref/color.palette.json" },
        { "$ref": "./ref/size.scale.json" },
        { "$ref": "./ref/font.json" },
        { "$ref": "./ref/motion.json" },
        { "$ref": "./ref/stroke.json" },
        { "$ref": "./ref/number.json" }
      ]
    },
    "sys": {
      "description": "Semantic slots.",
      "sources": [
        { "$ref": "./sys/color.json" },
        { "$ref": "./sys/space.json" },
        { "$ref": "./sys/radius.json" },
        { "$ref": "./sys/typography.json" },
        { "$ref": "./sys/shadow.json" },
        { "$ref": "./sys/border.json" },
        { "$ref": "./sys/motion.json" }
      ]
    },
    "cmp": {
      "description": "Component tokens.",
      "sources": [
        { "$ref": "./cmp/button.json" },
        { "$ref": "./cmp/card.json" },
        { "$ref": "./cmp/input.json" }
      ]
    }
  },
  "modifiers": {
    "mode": {
      "description": "Light/dark surface + text baseline.",
      "contexts": {
        "Light": [{ "$ref": "./themes/light.json" }],
        "Dark": [{ "$ref": "./themes/dark.json" }]
      },
      "default": "Light"
    },
    "brand": {
      "description": "Accent palette. `Default` leaves sys alone; `Brand A` overrides the accent scale.",
      "contexts": {
        "Default": [],
        "Brand A": [{ "$ref": "./themes/brand-a.json" }]
      },
      "default": "Default"
    }
  },
  "resolutionOrder": [
    { "$ref": "#/sets/ref" },
    { "$ref": "#/sets/sys" },
    { "$ref": "#/sets/cmp" },
    { "$ref": "#/modifiers/mode" },
    { "$ref": "#/modifiers/brand" }
  ]
}
