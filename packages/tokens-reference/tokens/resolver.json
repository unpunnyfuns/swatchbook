{
  "$schema": "https://design-tokens.org/tr/2025/drafts/resolver/",
  "version": "2025.10",
  "name": "swatchbook-reference",
  "description": "DTCG 2025.10 native resolver. Single `theme` modifier enumerates the five named compositions we care about in the storybook dogfood app.",
  "sets": {
    "ref": {
      "description": "Raw primitives (loaded but not emitted).",
      "sources": [
        { "$ref": "./ref/color.palette.json" },
        { "$ref": "./ref/size.scale.json" },
        { "$ref": "./ref/font.json" },
        { "$ref": "./ref/motion.json" },
        { "$ref": "./ref/stroke.json" },
        { "$ref": "./ref/number.json" }
      ]
    },
    "sys": {
      "description": "Semantic slots.",
      "sources": [
        { "$ref": "./sys/color.json" },
        { "$ref": "./sys/space.json" },
        { "$ref": "./sys/radius.json" },
        { "$ref": "./sys/typography.json" },
        { "$ref": "./sys/shadow.json" },
        { "$ref": "./sys/border.json" },
        { "$ref": "./sys/motion.json" }
      ]
    },
    "cmp": {
      "description": "Component tokens.",
      "sources": [
        { "$ref": "./cmp/button.json" },
        { "$ref": "./cmp/card.json" },
        { "$ref": "./cmp/input.json" }
      ]
    }
  },
  "modifiers": {
    "theme": {
      "description": "Named theme compositions.",
      "contexts": {
        "Light": [{ "$ref": "./themes/light.json" }],
        "Dark": [{ "$ref": "./themes/dark.json" }],
        "Light · Brand A": [
          { "$ref": "./themes/light.json" },
          { "$ref": "./themes/brand-a.json" }
        ],
        "Dark · Brand A": [
          { "$ref": "./themes/dark.json" },
          { "$ref": "./themes/brand-a.json" }
        ],
        "High Contrast": [{ "$ref": "./themes/high-contrast.json" }]
      },
      "default": "Light"
    }
  },
  "resolutionOrder": [
    { "$ref": "#/sets/ref" },
    { "$ref": "#/sets/sys" },
    { "$ref": "#/sets/cmp" },
    { "$ref": "#/modifiers/theme" }
  ]
}
