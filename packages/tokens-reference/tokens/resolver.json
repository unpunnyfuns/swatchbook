{
  "$schema": "https://design-tokens.org/tr/2025/drafts/resolver/",
  "version": "2025.10",
  "name": "swatchbook-reference",
  "description": "DTCG 2025.10 native resolver. Two layers (ref and sys) plus three independent modifiers — `mode` (light/dark baseline), `brand` (default/Brand A accent), and `contrast` (normal/high border + focus emphasis) — compose into 8 named themes. Component variation is carried by modes on sys; no `cmp` layer.",
  "sets": {
    "ref": {
      "description": "Raw primitives (loaded but not emitted).",
      "sources": [
        { "$ref": "./ref/color.palette.json" },
        { "$ref": "./ref/size.scale.json" },
        { "$ref": "./ref/font.json" },
        { "$ref": "./ref/motion.json" },
        { "$ref": "./ref/stroke.json" },
        { "$ref": "./ref/number.json" },
        { "$ref": "./ref/gradient.json" }
      ]
    },
    "sys": {
      "description": "Semantic slots.",
      "sources": [
        { "$ref": "./sys/color.json" },
        { "$ref": "./sys/space.json" },
        { "$ref": "./sys/radius.json" },
        { "$ref": "./sys/typography.json" },
        { "$ref": "./sys/shadow.json" },
        { "$ref": "./sys/border.json" },
        { "$ref": "./sys/motion.json" }
      ]
    }
  },
  "modifiers": {
    "mode": {
      "description": "Light/dark surface + text baseline.",
      "contexts": {
        "Light": [{ "$ref": "./themes/light.json" }],
        "Dark": [{ "$ref": "./themes/dark.json" }]
      },
      "default": "Light"
    },
    "brand": {
      "description": "Accent palette. `Default` leaves sys alone; `Brand A` overrides the accent scale.",
      "contexts": {
        "Default": [],
        "Brand A": [{ "$ref": "./themes/brand-a.json" }]
      },
      "default": "Default"
    },
    "contrast": {
      "description": "Border + focus emphasis. `Normal` leaves sys alone; `High` thickens borders and boosts the focus ring.",
      "contexts": {
        "Normal": [],
        "High": [{ "$ref": "./themes/contrast-high.json" }]
      },
      "default": "Normal"
    }
  },
  "resolutionOrder": [
    { "$ref": "#/sets/ref" },
    { "$ref": "#/sets/sys" },
    { "$ref": "#/modifiers/mode" },
    { "$ref": "#/modifiers/brand" },
    { "$ref": "#/modifiers/contrast" }
  ]
}
