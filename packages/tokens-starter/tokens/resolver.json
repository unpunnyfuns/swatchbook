{
  "$schema": "https://design-tokens.org/tr/2025/drafts/resolver/",
  "version": "2025.10",
  "name": "swatchbook-tokens-starter",
  "description": "Minimal resolver for the starter set. Flat token paths organized per `$type` — color, size, space — plus a single `theme` modifier (Light baseline).",
  "sets": {
    "tokens": {
      "description": "Flat DTCG tokens grouped by `$type`.",
      "sources": [
        { "$ref": "./color.json" },
        { "$ref": "./size.json" },
        { "$ref": "./space.json" }
      ]
    }
  },
  "modifiers": {
    "theme": {
      "contexts": {
        "Light": [{ "$ref": "./themes/light.json" }]
      },
      "default": "Light"
    }
  },
  "resolutionOrder": [
    { "$ref": "#/sets/tokens" },
    { "$ref": "#/modifiers/theme" }
  ]
}
