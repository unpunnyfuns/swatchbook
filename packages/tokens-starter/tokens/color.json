{
  "color": {
    "$type": "color",
    "$description": "Color tokens — raw primitives and semantic slots. Theme files override the semantic slots.",
    "neutral": {
      "0":   { "$value": "#ffffff" },
      "100": { "$value": "#f1f5f9" },
      "500": { "$value": "#64748b" },
      "900": { "$value": "#0f172a" }
    },
    "blue": {
      "500": { "$value": "#3b82f6" },
      "700": { "$value": "#1d4ed8" }
    },
    "surface":      { "$value": "{color.neutral.0}" },
    "surface-muted":{ "$value": "{color.neutral.100}" },
    "text":         { "$value": "{color.neutral.900}" },
    "text-muted":   { "$value": "{color.neutral.500}" },
    "text-inverse": { "$value": "{color.neutral.0}" },
    "accent": {
      "base":  { "$value": "{color.blue.500}" },
      "hover": { "$value": "{color.blue.700}" }
    },
    "border": { "$value": "{color.neutral.100}" }
  }
}
