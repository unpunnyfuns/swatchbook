{
  "color": {
    "sys": {
      "$type": "color",
      "$description": "Semantic color slots. Theme files override these.",
      "surface":   { "$value": "{color.ref.neutral.0}" },
      "surface-muted": { "$value": "{color.ref.neutral.100}" },
      "text":      { "$value": "{color.ref.neutral.900}" },
      "text-muted":{ "$value": "{color.ref.neutral.500}" },
      "text-inverse": { "$value": "{color.ref.neutral.0}" },
      "accent":    { "$value": "{color.ref.accent.500}" },
      "accent-hover": { "$value": "{color.ref.accent.700}" },
      "border":    { "$value": "{color.ref.neutral.100}" }
    }
  },
  "space": {
    "sys": {
      "$type": "dimension",
      "xs": { "$value": "{size.ref.100}" },
      "sm": { "$value": "{size.ref.200}" },
      "md": { "$value": "{size.ref.300}" },
      "lg": { "$value": "{size.ref.400}" },
      "xl": { "$value": "{size.ref.600}" }
    }
  }
}
