{
  "name": "@unpunnyfuns/swatchbook-tokens",
  "version": "0.0.0",
  "description": "Minimal DTCG design-token starter set for swatchbook consumers.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.14.0"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./css": "./dist/css/index.css",
    "./themes/*.json": "./dist/themes/*.json",
    "./tokens/*": "./tokens/*"
  },
  "files": [
    "dist",
    "tokens"
  ],
  "scripts": {
    "build": "node --no-warnings --experimental-strip-types build.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --deny-warnings -c ../../.oxlintrc.json build.ts",
    "format": "oxfmt -c ../../.oxfmtrc.json build.ts",
    "format:check": "oxfmt --check -c ../../.oxfmtrc.json build.ts"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@unpunnyfuns/swatchbook-core": "workspace:*",
    "typescript": "^6.0.0"
  }
}
